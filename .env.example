# ============================================================================
# Bite-GO - Variables compartidas por docker-compose
# ============================================================================
# Copia este archivo a `.env` en la raíz del proyecto y rellena los valores.
# Este `.env` lo lee docker-compose automáticamente para hacer substitución
# ${VARIABLE} dentro de docker-compose.yml.
#
# Para los secretos específicos del auth-service (SMTP, Cloudinary) usa el
# archivo `auth-service-bite-go/.env` (también hay un .env.example allí).
# ============================================================================

# --- JWT compartido entre los 3 microservicios ------------------------------
# IMPORTANTE: debe ser EXACTAMENTE el mismo valor en auth-service,
# Bite-go-admin y Bite-go-user o los tokens no validarán.
JWT_SECRET=BiteAndGoSuperSecretKey_ChangeMeInProduction_0123456789ABCDEFabcdef==!
JWT_ISSUER=BiteGoAuthService
JWT_AUDIENCE=BiteGoServices

# --- URLs de servicios ------------------------------------------------------
AUTH_SERVICE_URL=http://auth-service:3000
FRONTEND_URL=http://localhost:5173

# --- PostgreSQL del auth-service --------------------------------------------
AUTH_DB_USER=bitego
AUTH_DB_PASSWORD=bitego
AUTH_DB_NAME=bitego_auth_db
